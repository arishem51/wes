# ── Server ──
PORT=3000
WEB_ORIGIN=http://localhost:5173

# ── Database (DATABASE_URL takes precedence over PG* if set) ──
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wes
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=wes

# ── Auth ──
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
REFRESH_TTL_DAYS=7
RESET_TTL_MINUTES=30

# ── openTCS (existing) ──
OPENTCS_KERNEL_URL=http://localhost:55200
