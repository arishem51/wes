# ── Server ──
PORT=3000
WEB_ORIGIN=http://localhost:5173

# ── Database (DATABASE_URL takes precedence over PG* if set) ──
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wes
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=wes

# ── Auth ──
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=1d
REFRESH_TTL_DAYS=7
RESET_TTL_MINUTES=30

# ── Frontend links ──
APP_URL=http://localhost:5173

# ── SMTP mail ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="WES Console <your-email@gmail.com>"

# ── openTCS (existing) ──
# Native dev: http://localhost:55200
# Devcontainer: http://host.docker.internal:55200
OPENTCS_KERNEL_URL=http://localhost:55200
OPENTCS_MAP_AUTO_LOAD=false

# Vehicle operation vocabulary. Must match the loaded map's allowedOperation:
#   loopback -> PICK_UP / DROP_OFF   (maps/v7.xml, v7-bidir.xml, v7-simple.xml)
#   vda5050  -> liftUp  / liftDown   (maps/v7-vda5050.xml)
VEHICLE_TYPE=loopback
